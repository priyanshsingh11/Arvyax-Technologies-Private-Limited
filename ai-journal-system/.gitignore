# AI-Assisted Journal System - Master Gitignore

# -------------------------------------------------------------------
# Python (Backend)
# -------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
venv/
env/
ENV/
.venv/
.env/

# Testing / Coverage
.cache
.pytest_cache/
.noserc
nosetests.xml
coverage.xml
*.cover
.coverage
.coverage.*
.pypy_cache/
htmlcov/

# Type Checking
.mypy_cache/
.pyre/
.pytype/

# -------------------------------------------------------------------
# Node / Next.js (Frontend)
# -------------------------------------------------------------------
node_modules/
/frontend/node_modules/
/frontend/package-lock.json
/frontend/.next/
/frontend/out/
/frontend/build/
/frontend/.vercel/
/frontend/.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# -------------------------------------------------------------------
# Databases / Local Storage
# -------------------------------------------------------------------
*.db
*.db-journal
*.sqlite3
backend/journal.db

# -------------------------------------------------------------------
# Environment Variables & Secrets
# -------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
backend/.env
frontend/.env.local

# Allow .env.example (if we create one)
!.env.example

# -------------------------------------------------------------------
# OS & IDEs
# -------------------------------------------------------------------
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# IntelliJ / JetBrains
.idea/
*.iws
*.iml
*.ipr

# -------------------------------------------------------------------
# Misc
# -------------------------------------------------------------------
*.tmp
*.temp
*.swp
*.swo
.DS_Store
